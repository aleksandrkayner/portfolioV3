# Copy to server/.env for local development

NODE_ENV=development
PORT=3001
# Postgres.app: postgres://YOUR_MAC_USERNAME@localhost:5432/portfolio
# Docker:       postgres://portfolio:portfolio@localhost:5432/portfolio
DATABASE_URL=postgres://YOUR_MAC_USERNAME@localhost:5432/portfolio
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
CLIENT_URL=http://localhost:5173

# Email that receives new registration alerts
ADMIN_EMAIL=you@example.com

# Admin panel credentials (server/.env only — never commit real values)
ADMIN_LOGIN_EMAIL=admin@yourdomain.com
ADMIN_LOGIN_PASSWORD=YourSecurePass1!

# Optional OAuth (register redirect URI: http://localhost:5173/api/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
